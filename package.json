{
  "name": "captionkit",
  "version": "0.1.0",
  "description": "Convert and re-time subtitles locally — SRT ⇄ WebVTT, shift, scale, resync drift, fix overlaps. Exact millisecond timecode math, zero dependencies, no upload.",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsup",
    "build:web": "vite build",
    "dev": "vite",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "subtitles",
    "srt",
    "vtt",
    "webvtt",
    "captions",
    "srt-to-vtt",
    "subtitle-sync",
    "subtitle-converter",
    "timecode",
    "video",
    "accessibility",
    "zero-dependency"
  ],
  "author": "didrod205 (https://github.com/didrod205)",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/didrod205/captionkit.git"
  },
  "bugs": {
    "url": "https://github.com/didrod205/captionkit/issues"
  },
  "homepage": "https://didrod205.github.io/captionkit/",
  "devDependencies": {
    "tsup": "^8.3.5",
    "typescript": "^5.7.2",
    "vite": "^6.0.0",
    "vitest": "^2.1.8"
  }
}
